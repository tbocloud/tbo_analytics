  },
  {
   "fieldname": "standard_price",
   "fieldtype": "Currency",
   "label": "Standard Price",
   "read_only": 1,
   "description": "= Grand Total Cost ÷ (1 − Target Margin %). Hits your target margin exactly."
  },
  {
   "fieldname": "premium_price",
   "fieldtype": "Currency",
   "label": "Premium Price",
