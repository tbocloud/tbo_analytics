{
 "align_labels_right": 0,
 "creation": "2026-06-15 00:00:00.000000",
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "Implementation Estimate",
 "doctype": "Print Format",
 "font": "Default",
 "format_data": "",
 "html": "<div class=\"print-format\">\n  <div style=\"display:flex;justify-content:space-between;border-bottom:2px solid #2c3e50;padding-bottom:10px;margin-bottom:20px;\">\n    <div>\n      <h2 style=\"margin:0;font-size:20px;\">Implementation Estimate</h2>\n      <div style=\"color:#666;font-size:12px;\">{{ doc.name }}</div>\n    </div>\n    <div style=\"text-align:right;font-size:12px;line-height:1.6;\">\n      <div><strong>Client:</strong> {{ doc.client_name or '-' }}</div>\n      <div><strong>Date:</strong> {{ frappe.utils.formatdate(doc.enquiry_date) if doc.enquiry_date else '-' }}</div>\n      <div><strong>Duration:</strong> {{ doc.project_duration_months or 0 }} month(s)</div>\n      <div><strong>Status:</strong> {{ doc.status or 'Draft' }}</div>\n    </div>\n  </div>\n\n  <h3 style=\"border-bottom:1px solid #ccc;padding-bottom:4px;font-size:14px;text-transform:uppercase;color:#444;\">Module Scope &amp; Hours</h3>\n  <table class=\"table table-bordered\" style=\"width:100%;border-collapse:collapse;font-size:12px;\">\n    <thead>\n      <tr style=\"background:#f5f7fa;\">\n        <th style=\"padding:6px;text-align:left;\">Module</th>\n        <th style=\"padding:6px;text-align:left;\">Phase</th>\n        <th style=\"padding:6px;text-align:left;\">Priority</th>\n        <th style=\"padding:6px;text-align:right;\">Hours</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% set mt = namespace(h=0) %}\n      {% for m in doc.module_selections if m.is_included %}\n      <tr>\n        <td style=\"padding:6px;\">{{ m.module }}</td>\n        <td style=\"padding:6px;\">{{ m.phase or '-' }}</td>\n        <td style=\"padding:6px;\">{{ m.priority or '-' }}</td>\n        <td style=\"padding:6px;text-align:right;\">{{ \"%.1f\"|format(m.total_module_hours or m.final_hours or 0) }}</td>\n      </tr>\n      {% set mt.h = mt.h + (m.total_module_hours or m.final_hours or 0) %}\n      {% endfor %}\n      {% for c in doc.custom_module_requests %}\n      <tr>\n        <td style=\"padding:6px;\">{{ c.module_name }} <span style=\"color:#888;font-size:11px;\">(custom)</span></td>\n        <td style=\"padding:6px;\">{{ c.phase or '-' }}</td>\n        <td style=\"padding:6px;\">{{ c.priority or '-' }}</td>\n        <td style=\"padding:6px;text-align:right;\">{{ \"%.1f\"|format(c.total_hours or c.final_hours or 0) }}</td>\n      </tr>\n      {% set mt.h = mt.h + (c.total_hours or c.final_hours or 0) %}\n      {% endfor %}\n      <tr style=\"background:#eef;font-weight:bold;\">\n        <td colspan=\"3\" style=\"padding:6px;text-align:right;\">Total Module Hours</td>\n        <td style=\"padding:6px;text-align:right;\">{{ \"%.1f\"|format(mt.h) }}</td>\n      </tr>\n    </tbody>\n  </table>\n\n  <h3 style=\"border-bottom:1px solid #ccc;padding-bottom:4px;margin-top:20px;font-size:14px;text-transform:uppercase;color:#444;\">Team &amp; Allocation</h3>\n  <table class=\"table table-bordered\" style=\"width:100%;border-collapse:collapse;font-size:12px;\">\n    <thead>\n      <tr style=\"background:#f5f7fa;\">\n        <th style=\"padding:6px;text-align:left;\">Name</th>\n        <th style=\"padding:6px;text-align:left;\">Role</th>\n        <th style=\"padding:6px;text-align:right;\">Allocated Hours</th>\n        <th style=\"padding:6px;text-align:right;\">Hourly Cost (Rs)</th>\n        <th style=\"padding:6px;text-align:right;\">Cost (Rs)</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% set tt = namespace(h=0, c=0) %}\n      {% for t in doc.team_members if t.is_active_in_current_version %}\n      <tr>\n        <td style=\"padding:6px;\">{{ t.employee_name or t.employee or '-' }}</td>\n        <td style=\"padding:6px;\">{{ t.role or '-' }}</td>\n        <td style=\"padding:6px;text-align:right;\">{{ \"%.1f\"|format(t.allocated_hours or 0) }}</td>\n        <td style=\"padding:6px;text-align:right;\">{{ \"{:,.0f}\".format(t.hourly_cost or 0) }}</td>\n        <td style=\"padding:6px;text-align:right;\">{{ \"{:,.0f}\".format(t.total_cost or 0) }}</td>\n      </tr>\n      {% set tt.h = tt.h + (t.allocated_hours or 0) %}\n      {% set tt.c = tt.c + (t.total_cost or 0) %}\n      {% endfor %}\n      <tr style=\"background:#eef;font-weight:bold;\">\n        <td colspan=\"2\" style=\"padding:6px;text-align:right;\">Total</td>\n        <td style=\"padding:6px;text-align:right;\">{{ \"%.1f\"|format(tt.h) }}</td>\n        <td></td>\n        <td style=\"padding:6px;text-align:right;\">{{ \"{:,.0f}\".format(tt.c) }}</td>\n      </tr>\n    </tbody>\n  </table>\n\n  <h3 style=\"border-bottom:1px solid #ccc;padding-bottom:4px;margin-top:20px;font-size:14px;text-transform:uppercase;color:#444;\">Pricing &amp; Profitability</h3>\n\n  <div style=\"display:flex;gap:20px;flex-wrap:wrap;\">\n    <div style=\"flex:1;min-width:280px;\">\n      <h4 style=\"font-size:12px;color:#666;text-transform:uppercase;margin:6px 0;\">Cost Breakdown</h4>\n      <table class=\"table table-bordered\" style=\"width:100%;border-collapse:collapse;font-size:12px;\">\n        <tr><td style=\"padding:6px;\">Team Cost</td><td style=\"padding:6px;text-align:right;\">Rs {{ \"{:,.0f}\".format(doc.team_cost_total or 0) }}</td></tr>\n        <tr><td style=\"padding:6px;\">Direct Costs</td><td style=\"padding:6px;text-align:right;\">Rs {{ \"{:,.0f}\".format(doc.direct_cost_total or 0) }}</td></tr>\n        <tr><td style=\"padding:6px;\">Indirect Costs</td><td style=\"padding:6px;text-align:right;\">Rs {{ \"{:,.0f}\".format(doc.indirect_cost_total or 0) }}</td></tr>\n        <tr><td style=\"padding:6px;\">Infrastructure Costs</td><td style=\"padding:6px;text-align:right;\">Rs {{ \"{:,.0f}\".format(doc.infrastructure_cost_total or 0) }}</td></tr>\n        <tr><td style=\"padding:6px;\">Post Go-Live Support</td><td style=\"padding:6px;text-align:right;\">Rs {{ \"{:,.0f}\".format(doc.total_support_cost or 0) }}</td></tr>\n        <tr style=\"background:#eef;font-weight:bold;\"><td style=\"padding:6px;\">Grand Total Cost</td><td style=\"padding:6px;text-align:right;\">Rs {{ \"{:,.0f}\".format(doc.grand_total_cost or 0) }}</td></tr>\n      </table>\n    </div>\n\n    <div style=\"flex:1;min-width:280px;\">\n      <h4 style=\"font-size:12px;color:#666;text-transform:uppercase;margin:6px 0;\">Pricing Bands</h4>\n      <table class=\"table table-bordered\" style=\"width:100%;border-collapse:collapse;font-size:12px;\">\n        <tr><td style=\"padding:6px;\">Base</td><td style=\"padding:6px;text-align:right;\">Rs {{ \"{:,.0f}\".format(doc.floor_price or 0) }}</td></tr>\n        <tr><td style=\"padding:6px;\">Standard (Target Margin {{ \"%.0f\"|format(doc.target_margin_pct or 0) }}%)</td><td style=\"padding:6px;text-align:right;\">Rs {{ \"{:,.0f}\".format(doc.standard_price or 0) }}</td></tr>\n        <tr><td style=\"padding:6px;\">Premium</td><td style=\"padding:6px;text-align:right;\">Rs {{ \"{:,.0f}\".format(doc.premium_price or 0) }}</td></tr>\n        {% if doc.use_custom_price %}\n        <tr style=\"background:#fff9e6;\"><td style=\"padding:6px;\">Custom (override)</td><td style=\"padding:6px;text-align:right;\">Rs {{ \"{:,.0f}\".format(doc.custom_price or 0) }}</td></tr>\n        {% endif %}\n      </table>\n    </div>\n  </div>\n\n  <div style=\"margin-top:20px;padding:14px;background:#f0f4f8;border-left:4px solid #2c3e50;border-radius:4px;\">\n    <div style=\"display:flex;justify-content:space-between;flex-wrap:wrap;gap:20px;\">\n      <div>\n        <div style=\"font-size:11px;color:#666;text-transform:uppercase;\">Recommended Price</div>\n        <div style=\"font-size:22px;font-weight:bold;color:#2c3e50;\">Rs {{ \"{:,.0f}\".format(doc.recommended_price or 0) }}</div>\n        <div style=\"font-size:11px;color:#888;\">{{ doc.recommended_band or '-' }}{% if doc.use_custom_price %} &middot; custom override{% endif %}</div>\n      </div>\n      <div style=\"text-align:right;font-size:12px;color:#666;line-height:1.8;\">\n        <div>Margin at Recommended: <b>{{ \"%.1f\"|format(doc.margin_at_recommended or 0) }}%</b></div>\n        <div>Price per Hour: <b>Rs {{ \"{:,.0f}\".format(doc.price_per_hour or 0) }}</b></div>\n        <div>Suggested AMC (15%): <b>Rs {{ \"{:,.0f}\".format(doc.amc_suggested or 0) }}/yr</b></div>\n      </div>\n    </div>\n  </div>\n\n  {% if doc.pricing_notes %}\n  <div style=\"margin-top:16px;\">\n    <h4 style=\"font-size:12px;color:#666;text-transform:uppercase;margin:6px 0;\">Pricing Notes</h4>\n    <div style=\"padding:10px;background:#fafbfc;border:1px solid #e0e6ed;border-radius:4px;font-size:12px;\">\n      {{ doc.pricing_notes }}\n    </div>\n  </div>\n  {% endif %}\n</div>",
